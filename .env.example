# Chat bridge settings (local-only)
CHAT_PROVIDER=telegram
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_OWNER_CHAT_ID=replace_me
TELEGRAM_OWNER_USER_ID=replace_me
TELEGRAM_BACKUP_CHAT_ID=
TELEGRAM_BACKUP_USER_ID=
SLACK_APP_TOKEN=replace_me
SLACK_BOT_TOKEN=replace_me

# Ollama local endpoint
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional Hermes runtime auth (if hermes.enabled=true in config/projects.yaml)
HERMES_API_KEY=replace_me_if_required
