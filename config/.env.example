# ============================================================
# AI Holding Company — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Ollama ---
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=mistral:7b-instruct-v0.3-q4_K_M

# --- Telegram Bot ---
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# --- OpenClaw ---
OPENCLAW_LOG_LEVEL=info

# --- Bot Log Paths (Windows paths — used by monitoring tools) ---
FOREX_BOT_LOG=C:\Users\J\bots\forex\logs\trades.log
GOLD_BOT_LOG=C:\Users\J\bots\gold\logs\trades.log

# --- VPS SSH (for Polymarket bot) ---
VPS_HOST=your-vps-ip
VPS_USER=your-ssh-user
VPS_KEY_PATH=C:\Users\J\.ssh\id_rsa
POLYMARKET_REMOTE_LOG=/home/user/polymarket/logs/trades.log

# --- Website URLs ---
WEBSITE_1=https://your-website-1.com
WEBSITE_2=https://your-website-2.com
